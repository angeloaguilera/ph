{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "types": ["node"],
    "outDir": "./dist",
    "strictPropertyInitialization": false

  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
